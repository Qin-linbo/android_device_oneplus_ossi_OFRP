<filter-conf>
    <version>2025090801</version>
    <isOpen>1</isOpen>
    <filter-name>sys_scene_touch_config</filter-name>

		<device name="default">
			<default>
				<!-- 手写笔锁点参数 -->
				<command name="pen_sensitive_level"	value="mod para_effect pen_sensitive_level:254"/>
			</default>

			<!--所有修改均为增量修改，所有增量修改都是基于上面的default配置，包括各个package里面的default和activity -->
			<packages>
				<!--本配置针对应用的包名列表 -->
				<pkg_list>
					<item name="com.coloros.filemanager" /><!---文件管理-->
					<item name="com.coloros.gallery3d" /><!---相册-->
					<item name="com.oplus.engineermode" /><!---工模-->
					<item name="cn.xuexi.android" /><!---学习强国-->
					<item name="com.netease.yyslscn" /><!---燕云十六声-->
				</pkg_list>
					<!--包名列表中，某个包的默认配置，基于外层的default配置增量修改，如果配置了某个包名的场景，必须配置一个如下对应的默认配置 -->
				<default>
					<!-- 优化触控锁点参数 -->
					<command name="pen_sensitive_level"	value="mod para_effect pen_sensitive_level:15"/>
				</default>
				<!-- 进入以下列表apk的特定界面的新的参数 -->
				<!--包名列表中，某个包里面某个activity的配置，仍是基于外层的default配置增量修改，而非包名的default修改 -->
				<activity pkg_name="com.coloros.gallery3d" activity_name="com.oplus.gallery.searchpage.SearchActivity">
					<command name="pen_sensitive_level"	value="mod para_effect pen_sensitive_level:254"/>
				</activity>
				<activity pkg_name="com.coloros.filemanager" activity_name="com.oplus.filemanager.category.globalsearch.ui.GlobalSearchActivity">
					<command name="pen_sensitive_level"	value="mod para_effect pen_sensitive_level:254"/>
				</activity>
			</packages>

			<default>
				<!-- 手写笔锁点参数 -->
				<command name="pen_sensitive_level"	value="mod para_effect pen_sensitive_level:254"/>
			</default>

			<!--所有修改均为增量修改，所有增量修改都是基于上面的default配置，包括各个package里面的default和activity -->
			<packages>
				<!--本配置针对应用的包名列表 -->
				<pkg_list>
					<item name="com.coloros.note" /><!---便签-->
					<item name="cn.wps.moffice_eng" /><!---WPS Office-->
					<item name="com.jideos.jnotes" /><!---云记-->
					<item name="com.newskyer.draw" /><!---享做笔记-->
					<item name="com.orion.notein" /><!---Notein一笔记-->
					<item name="com.freenotes.freenotes" /><!---自由笔记-->
					<item name="com.onyx.galaxy.note" /><!---StarNote笔记-->
					<item name="com.topstack.kilonotes.pad" /><!---千本笔记-->
					<item name="com.yinxiang" /><!---印象笔记-->
					<item name="com.microsoft.office.onenote" /><!---OneNote-->
					<item name="net.huanci.hsjpro" /><!---画世界Pro-->
					<item name="com.aige.hipaint" /><!---绘王(HiPaint)-->
					<item name="com.tophatch.concepts.china" /><!---概念画板-->
					<item name="jp.ne.ibis.ibispaintx.app" /><!---爱笔思画X-->
					<item name="jp.ne.ibis.ibispaintx.app.hms" /><!---爱笔思画X-->
				</pkg_list>
					<!--包名列表中，某个包的默认配置，基于外层的default配置增量修改，如果配置了某个包名的场景，必须配置一个如下对应的默认配置 -->
				<default>
					<!-- 优化触控锁点参数 -->
					<command name="pen_sensitive_level"	value="mod para_effect pen_sensitive_level:3"/>
				</default>
			</packages>

			<default>
				<!-- 抬手滤波参数 -->
				<command name="touch_leave_jitter"	value="mod para_effect touch_leave_jitter:0"/>
			</default>
			<!--所有修改均为增量修改，所有增量修改都是基于上面的default配置，包括各个package里面的default和activity -->
			<packages>
				<!--本配置针对应用的包名列表 -->
				<pkg_list>
					<item name="oplus.inputting_method" /><!---输入法-->
				</pkg_list>
					<!--包名列表中，某个包的默认配置，基于外层的default配置增量修改，如果配置了某个包名的场景，必须配置一个如下对应的默认配置 -->
				<default>
					<!-- 优化抬手滤波参数 -->
					<command name="touch_leave_jitter"	value="mod para_effect touch_leave_jitter:1"/>
				</default>
			</packages>

		</device>
</filter-conf>
